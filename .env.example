# Dradis Map — Environment Configuration
# Copy this file to .env and fill in your values

# Full URL to your Dradis instance (no trailing slash)
DRADIS_HOST=https://192.168.68.73

# Your Dradis API token (from Dradis → Account Settings → API token)
DRADIS_TOKEN=your_api_token_here

# Optional: accept self-signed certificates from Dradis.
# Safer than NODE_TLS_REJECT_UNAUTHORIZED=0 because it only applies to this
# app's outbound requests, not the entire Node process.
# Use on trusted local networks only.
# TRUST_SELF_SIGNED=true

# Optional: path to your Dradis CA certificate (most secure option for self-signed certs).
# Export the cert from your browser: click the padlock -> Certificate -> Export
# CA_CERT_PATH=/path/to/dradis-ca.pem

# Optional: port to run the local server on (default: 3000)
# PORT=3000
